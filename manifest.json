{
  "manifest_version": 3,
  "name": "Chat Navigator",
  "version": "1.1",
  "description": "Navigate AI chats easily",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}