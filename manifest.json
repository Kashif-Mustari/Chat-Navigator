{
  "manifest_version": 3,
  "name": "Chat Navigator",
  "version": "1.0",
  "description": "Navigate chat questions easily",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://chat.openai.com/*"],
  "content_scripts": [
    {
      "matches": ["https://chat.openai.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}